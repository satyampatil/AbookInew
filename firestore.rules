rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserDoc(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function hasOnlyAllowedBookFields() {
      return request.resource.data.keys().hasOnly([
        'title', 'genre', 'description', 'image_prompt', 'cover_hex_bg',
        'cover_hex_text', 'pages', 'coverUrl', 'createdAt', 'userId',
        'authorName', 'ratings', 'originalUserId', 'publicId'
      ]);
    }

    match /users/{userId} {
      allow read: if ownsUserDoc(userId);
      allow create, update: if ownsUserDoc(userId)
        && request.resource.data.keys().hasOnly([
          'avatarConfig', 'email', 'updatedAt', 'preferences', 'badges'
        ]);
      allow delete: if false;

      match /gamification/{docId} {
        allow read, create, update: if ownsUserDoc(userId);
        allow delete: if false;
      }
    }

    match /artifacts/{appId}/users/{userId}/books/{bookId} {
      allow read, delete: if ownsUserDoc(userId);
      allow create, update: if ownsUserDoc(userId)
        && (!('userId' in request.resource.data) || request.resource.data.userId == userId);
    }

    match /artifacts/{appId}/public/data/books/{bookId} {
      allow read: if true;
      allow create: if signedIn()
        && hasOnlyAllowedBookFields()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.originalUserId == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.userId == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ratings'])
      );
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /artifacts/{appId}/public/data/active_readers/{userId} {
      allow read: if true;
      allow create, update, delete: if ownsUserDoc(userId);
    }

    match /artifacts/{appId}/public/data/site_feedback/{commentId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1000;
      allow update: if false;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
